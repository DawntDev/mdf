# =============================================================================
# MDF Dictionary Extractor - Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in the values.
# `load_dotenv()` is called exclusively from main.py — never from services.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development                # development | staging | production
APP_LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
APP_HOST=0.0.0.0
APP_PORT=8000
MAX_UPLOAD_MB=50                   # Hard cap for uploaded PDFs

# -----------------------------------------------------------------------------
# LLM Providers
# -----------------------------------------------------------------------------
# Set only the keys for providers you want enabled. Absent keys mean the
# provider is filtered out of /api/v1/models and /api/v1/quote.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=

# -----------------------------------------------------------------------------
# OCR (automatic fallback)
# -----------------------------------------------------------------------------
# OCR is triggered automatically when native PDF text extraction yields no
# usable text (scanned / image-based PDFs). It requires a local tesseract
# binary. If TESSERACT_CMD is empty, pytesseract will search $PATH.
TESSERACT_CMD=                     # Absolute path to tesseract binary (Windows: C:\Program Files\Tesseract-OCR\tesseract.exe)
OCR_LANGUAGES=spa+eng              # Tesseract language packs to load
OCR_DPI=300                        # Render DPI for rasterizing pages prior to OCR

# -----------------------------------------------------------------------------
# Extraction behavior
# -----------------------------------------------------------------------------
PDF_IMAGE_TEXT_RATIO_THRESHOLD=0.02 # chars_per_pixel below this => image-based
PDF_PAGE_SAMPLE_SIZE=5              # Pages sampled for type detection
AGENT_MAX_RETRIES=2                 # Retries on validation failure per page
AGENT_TEMPERATURE=0.0               # Deterministic by default
